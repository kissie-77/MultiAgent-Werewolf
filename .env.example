# ── 通用 LLM 配置 ──────────────────────────────────
# 玩家 Agent 使用的 API Key（在 player_configs 中通过 api_key_env 引用）
WEREWOLF_API_KEY=your-api-key-here

# ── ReMe 记忆模块配置 ────────────────────────────────
# LLM 用于工作记忆语义压缩（OpenAI 兼容端点）
REME_LLM_API_KEY=your-llm-api-key
REME_LLM_BASE_URL=https://your-llm-endpoint/v1

# Embedding 用于语义检索（OpenAI 兼容端点，如 DashScope）
REME_EMBEDDING_API_KEY=your-embedding-api-key
REME_EMBEDDING_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
