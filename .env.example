# LLM Werewolf — Environment template
# Copy:  cp .env.example .env
# Fill only the providers you use (sparse config is fine).
#
# Standard match boards (standard-4p … standard-16p) default to 豆包 (doubao).
# Mixed-model seats will resolve keys via provider_id → variables below.
# See docs/interface/PROVIDERS.md and provider_registry.py for the full map.

# ============================================================
# LLM providers (8 supported vendors)
# Pattern: *_API_KEY (secret) + optional *_MODEL / *_BASE_URL / *_EP
# ============================================================

# --- doubao 豆包 (Volcengine Ark) — DEFAULT for standard-*p.yaml ---
ARK_API_KEY=
ARK_EP=

# --- deepseek (DS) ---
DEEPSEEK_API_KEY=
# DEEPSEEK_MODEL=deepseek-v4-flash

# --- openai (GPT) ---
OPENAI_API_KEY=
# OPENAI_MODEL=gpt-4o

# --- gemini ---
GEMINI_API_KEY=
# GEMINI_MODEL=gemini-2.0-flash

# --- claude (Anthropic) ---
ANTHROPIC_API_KEY=
# ANTHROPIC_MODEL=claude-sonnet-4-20250514

# --- kimi (Moonshot; proxy: set KIMI_BASE_URL=https://www.vibeapi.cn/v1) ---
KIMI_API_KEY=
# KIMI_BASE_URL=https://api.moonshot.cn/v1
# KIMI_MODEL=kimi-k2.5

# --- glm 智谱 ---
GLM_API_KEY=
# GLM_MODEL=glm-4-flash

# --- minimax ---
MINIMAX_API_KEY=
MINIMAX_GROUP_ID=
# MINIMAX_MODEL=abab6.5s-chat

# ============================================================
# Runtime / API server
# ============================================================

# Pause between serialized AgentScope calls (seconds); reduces 429s
AGENT_SERIAL_DELAY_SECONDS=1.0

# Protect POST/GET /api/v1/settings/api-keys (browser → .env writer)
# WEREWOLF_SETTINGS_TOKEN=change-me

# /ready LLM key check (0 = skip for UI-only local dev)
OBS_READY_REQUIRE_LLM=1

# CORS for werewolf-api (comma-separated)
# WEREWOLF_CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# ============================================================
# Legacy aliases (optional — prefer KIMI_* for new setups)
# ============================================================
# VIBE_API_KEY=          # old Kimi/VibeAPI proxy key
# MOONSHOT_API_KEY=      # Moonshot official alias
# XAI_API_KEY=           # xAI Grok (not in default 8-vendor set)
