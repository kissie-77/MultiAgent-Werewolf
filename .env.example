# LLM Werewolf - Environment Configuration
# Copy this file to .env and fill in your API keys:
#   cp .env.example .env
#
# Player/model settings live in configs/*.yaml (see configs/example.yaml).

# ============================================================
# API Keys (fill in providers you use)
# ============================================================

OPENAI_API_KEY=your_openai_api_key_here
ANTHROPIC_API_KEY=your_anthropic_api_key_here
GEMINI_API_KEY=your_gemini_api_key_here
XAI_API_KEY=your_xai_api_key_here
DEEPSEEK_API_KEY=your_deepseek_api_key_here

# Volcengine Ark (Doubao) — set api_key_env: ARK_API_KEY and model_env: ARK_EP in YAML
ARK_API_KEY=your_ark_api_key_here
ARK_EP=your_ark_endpoint_id_here

# Pause between serialized AgentScope API calls (seconds); reduces 429 rate limits
AGENT_SERIAL_DELAY_SECONDS=1.0

# ============================================================
# Usage
# ============================================================
# 1. Copy this file: cp .env.example .env
# 2. Fill API keys above for providers referenced in your YAML
# 3. Copy a config: cp configs/example.yaml configs/my_game.yaml
# 4. Run: uv run llm-werewolf --config configs/my_game.yaml
# 5. Test Ark: uv run python scripts/test_ark_connectivity.py
