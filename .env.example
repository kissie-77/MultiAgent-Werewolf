# LLM Werewolf - Environment Configuration
# Copy this file to .env and fill in your API keys:
#   cp .env.example .env
#
# Player/model settings live in configs/*.yaml (see configs/example.yaml).

# ============================================================
# API Keys (fill in providers you use)
# ============================================================

OPENAI_API_KEY=your_openai_api_key_here
ANTHROPIC_API_KEY=your_anthropic_api_key_here
GEMINI_API_KEY=your_gemini_api_key_here
XAI_API_KEY=your_xai_api_key_here
DEEPSEEK_API_KEY=your_deepseek_api_key_here

# Volcengine Ark (Doubao) — set api_key_env: ARK_API_KEY and model_env: ARK_EP in YAML
ARK_API_KEY=your_ark_api_key_here
ARK_EP=your_ark_endpoint_id_here
# Friendly name shown in the game setup UI (optional; avoids showing raw ep- ids)
ARK_EP_DISPLAY=豆包 Seed 1.6 极速版

# Optional friendly labels for other providers (shown instead of raw model ids)
DEEPSEEK_MODEL_DISPLAY=DeepSeek V4 Flash
OPENAI_MODEL_DISPLAY=GPT-4o
GEMINI_MODEL_DISPLAY=Gemini 2.0 Flash
ANTHROPIC_MODEL_DISPLAY=Claude Sonnet 4
KIMI_MODEL_DISPLAY=Kimi K2.5
GLM_MODEL_DISPLAY=GLM-4 Flash
MINIMAX_MODEL_DISPLAY=MiniMax abab6.5s

# Pause between serialized AgentScope API calls (seconds); reduces 429 rate limits
AGENT_SERIAL_DELAY_SECONDS=1.0

# ============================================================
# API readiness (/ready endpoint)
# ============================================================
# Set to 0 to skip LLM API key check (local UI dev without providers).
# OBS_READY_REQUIRE_ARK is a deprecated alias; prefer OBS_READY_REQUIRE_LLM.
OBS_READY_REQUIRE_LLM=1

# ============================================================
# Frontend (Vite dev only — optional)
# ============================================================
# Prefer editing frontend/.env.development (committed default) instead of duplicating here.
# Only VITE_* build-time vars belong under frontend/; LLM secrets stay in root .env above.
# VITE_API_PROXY=http://127.0.0.1:8010

# ============================================================
# Usage
# ============================================================
# 1. Copy this file: cp .env.example .env
# 2. Fill API keys above for providers referenced in your YAML
# 3. Web UI: see README.md §本地全栈开发 and docs/frontend/DEV.md
# 4. CLI: cp configs/example.yaml configs/my_game.yaml && uv run llm-werewolf --config ...
# 5. Test Ark: uv run python scripts/test_ark_connectivity.py
